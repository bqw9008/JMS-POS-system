<UserControl x:Class="POS_system_cs.UI.Wpf.Controls.ReportsPage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Grid Margin="22">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <WrapPanel Margin="0,0,0,14" VerticalAlignment="Center">
            <StackPanel MinWidth="260" Margin="0,0,18,0">
                <TextBlock x:Name="TitleText" FontSize="24" FontWeight="Bold" Foreground="#1F2A2E" />
                <TextBlock x:Name="DescriptionText" Foreground="#5B6969" TextWrapping="Wrap" Margin="0,4,0,0" />
            </StackPanel>
            <TextBlock x:Name="FromLabel" VerticalAlignment="Center" Margin="12,0,8,0" />
            <DatePicker x:Name="FromDatePicker" Width="140" />
            <TextBlock x:Name="ToLabel" VerticalAlignment="Center" Margin="12,0,8,0" />
            <DatePicker x:Name="ToDatePicker" Width="140" />
            <Button x:Name="RefreshButton" Height="34" MinWidth="76" Margin="8,0,0,0" Padding="14,0" BorderThickness="0" Background="#52796F" Foreground="#FCFAF4" Click="RefreshButton_Click" />
            <Button x:Name="Last30Button" Height="34" MinWidth="76" Margin="8,0,0,0" Padding="14,0" Background="#ECF1E8" Foreground="#1F2A2E" Click="Last30Button_Click" />
            <Button x:Name="ThisMonthButton" Height="34" MinWidth="76" Margin="8,0,0,0" Padding="14,0" Background="#ECF1E8" Foreground="#1F2A2E" Click="ThisMonthButton_Click" />
        </WrapPanel>

        <UniformGrid Grid.Row="1" Columns="5" Margin="0,0,0,14">
            <Border Margin="0,0,10,0" Padding="16" Background="#FCFAF4" BorderBrush="#DAE0D7" BorderThickness="1" CornerRadius="18">
                <StackPanel><TextBlock x:Name="TodaySalesLabel" Foreground="#5B6969" /><TextBlock x:Name="SalesText" FontSize="24" FontWeight="Bold" Margin="0,10,0,0" /></StackPanel>
            </Border>
            <Border Margin="0,0,10,0" Padding="16" Background="#FCFAF4" BorderBrush="#DAE0D7" BorderThickness="1" CornerRadius="18">
                <StackPanel><TextBlock x:Name="TodayOrdersLabel" Foreground="#5B6969" /><TextBlock x:Name="OrdersText" FontSize="24" FontWeight="Bold" Margin="0,10,0,0" /></StackPanel>
            </Border>
            <Border Margin="0,0,10,0" Padding="16" Background="#FCFAF4" BorderBrush="#DAE0D7" BorderThickness="1" CornerRadius="18">
                <StackPanel><TextBlock x:Name="TodayQuantityLabel" Foreground="#5B6969" /><TextBlock x:Name="QuantityText" FontSize="24" FontWeight="Bold" Margin="0,10,0,0" /></StackPanel>
            </Border>
            <Border Margin="0,0,10,0" Padding="16" Background="#FCFAF4" BorderBrush="#DAE0D7" BorderThickness="1" CornerRadius="18">
                <StackPanel><TextBlock x:Name="StockQuantityLabel" Foreground="#5B6969" /><TextBlock x:Name="StockText" FontSize="24" FontWeight="Bold" Margin="0,10,0,0" /></StackPanel>
            </Border>
            <Border Margin="0,0,10,0" Padding="16" Background="#FCFAF4" BorderBrush="#DAE0D7" BorderThickness="1" CornerRadius="18">
                <StackPanel><TextBlock x:Name="LowStockLabel" Foreground="#5B6969" /><TextBlock x:Name="LowText" FontSize="24" FontWeight="Bold" Margin="0,10,0,0" /></StackPanel>
            </Border>
        </UniformGrid>

        <Border Grid.Row="2" Margin="0,0,0,14" Padding="16" Background="#FCFAF4" BorderBrush="#DAE0D7" BorderThickness="1" CornerRadius="18">
            <TabControl>
                <TabItem x:Name="DailyTab" Padding="12,6"><DataGrid x:Name="DailyGrid" AutoGenerateColumns="False" CanUserAddRows="False" CanUserDeleteRows="False" IsReadOnly="True" RowHeaderWidth="0" RowHeight="40" ColumnHeaderHeight="40" GridLinesVisibility="Horizontal" Background="#FCFAF4" BorderThickness="0" FontSize="13.5" /></TabItem>
                <TabItem x:Name="WeeklyTab" Padding="12,6"><DataGrid x:Name="WeeklyGrid" AutoGenerateColumns="False" CanUserAddRows="False" CanUserDeleteRows="False" IsReadOnly="True" RowHeaderWidth="0" RowHeight="40" ColumnHeaderHeight="40" GridLinesVisibility="Horizontal" Background="#FCFAF4" BorderThickness="0" FontSize="13.5" /></TabItem>
                <TabItem x:Name="MonthlyTab" Padding="12,6"><DataGrid x:Name="MonthlyGrid" AutoGenerateColumns="False" CanUserAddRows="False" CanUserDeleteRows="False" IsReadOnly="True" RowHeaderWidth="0" RowHeight="40" ColumnHeaderHeight="40" GridLinesVisibility="Horizontal" Background="#FCFAF4" BorderThickness="0" FontSize="13.5" /></TabItem>
            </TabControl>
        </Border>

        <Border Grid.Row="3" Padding="16" Background="#FCFAF4" BorderBrush="#DAE0D7" BorderThickness="1" CornerRadius="18">
            <TabControl>
                <TabItem x:Name="TopSellingTab" Padding="12,6"><DataGrid x:Name="TopGrid" AutoGenerateColumns="False" CanUserAddRows="False" CanUserDeleteRows="False" IsReadOnly="True" RowHeaderWidth="0" RowHeight="40" ColumnHeaderHeight="40" GridLinesVisibility="Horizontal" Background="#FCFAF4" BorderThickness="0" FontSize="13.5" /></TabItem>
                <TabItem x:Name="SlowSellingTab" Padding="12,6"><DataGrid x:Name="SlowGrid" AutoGenerateColumns="False" CanUserAddRows="False" CanUserDeleteRows="False" IsReadOnly="True" RowHeaderWidth="0" RowHeight="40" ColumnHeaderHeight="40" GridLinesVisibility="Horizontal" Background="#FCFAF4" BorderThickness="0" FontSize="13.5" /></TabItem>
            </TabControl>
        </Border>
    </Grid>
</UserControl>
