<Window x:Class="POS_system_cs.UI.Wpf.Controls.QuantityDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Width="380"
        Height="210"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        Background="{StaticResource ShellBackgroundBrush}"
        FontFamily="Microsoft YaHei UI">
    <Grid Margin="18">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <TextBlock x:Name="ProductText"
                   FontSize="15"
                   Foreground="{StaticResource TextBrush}"
                   TextTrimming="CharacterEllipsis" />
        <TextBox x:Name="QuantityBox"
                 Grid.Row="1"
                 Height="40"
                 FontSize="16"
                 TextAlignment="Right"
                 VerticalContentAlignment="Center"
                 Margin="0,16,0,16" />
        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right">
            <Button x:Name="OkButton"
                    MinWidth="90"
                    Height="34"
                    Margin="8,0,0,0"
                    Padding="12,0"
                    BorderThickness="0"
                    Background="{StaticResource PrimaryBrush}"
                    Foreground="{StaticResource PrimaryForegroundBrush}"
                    IsDefault="True"
                    Click="OkButton_Click" />
            <Button x:Name="CancelButton"
                    MinWidth="82"
                    Height="34"
                    Margin="8,0,0,0"
                    Padding="12,0"
                    BorderBrush="{StaticResource BorderSoftBrush}"
                    BorderThickness="1"
                    Background="{StaticResource SecondaryButtonBrush}"
                    Foreground="{StaticResource TextBrush}"
                    IsCancel="True" />
        </StackPanel>
    </Grid>
</Window>


