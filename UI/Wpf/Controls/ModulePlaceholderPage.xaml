<UserControl x:Class="POS_system_cs.UI.Wpf.Controls.ModulePlaceholderPage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Grid Margin="28">
        <Border Style="{StaticResource CardBorderStyle}">
            <StackPanel MinWidth="260" Margin="0,0,18,0">
                <TextBlock x:Name="TitleText" Style="{StaticResource PageTitleTextStyle}" />
                <TextBlock x:Name="DescriptionText" Style="{StaticResource DescriptionTextStyle}" />
            </StackPanel>
        </Border>
    </Grid>
</UserControl>


