<UserControl x:Class="POS_system_cs.UI.Wpf.Controls.SettingsPage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Grid Margin="22">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <StackPanel Margin="0,0,0,14">
            <TextBlock x:Name="TitleText" Style="{StaticResource PageTitleTextStyle}" />
            <TextBlock x:Name="DescriptionText" Style="{StaticResource DescriptionTextStyle}" />
        </StackPanel>

        <Border Grid.Row="1" Style="{StaticResource CardBorderStyle}" Padding="18">
            <ScrollViewer VerticalScrollBarVisibility="Auto">
                <StackPanel MaxWidth="860" HorizontalAlignment="Left">
                    <TextBlock x:Name="EditNoticeText"
                               Foreground="{StaticResource MutedTextBrush}"
                               TextWrapping="Wrap"
                               Margin="0,0,0,18" />

                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="210" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>

                        <TextBlock x:Name="StoreNameLabel" Foreground="{StaticResource MutedTextBrush}" Margin="0,0,16,12" VerticalAlignment="Center" />
                        <TextBox x:Name="StoreNameBox" Grid.Column="1" Style="{StaticResource TextBoxBaseStyle}" />

                        <TextBlock x:Name="DatabasePathLabel" Grid.Row="1" Foreground="{StaticResource MutedTextBrush}" Margin="0,0,16,12" VerticalAlignment="Center" />
                        <TextBox x:Name="DatabasePathBox" Grid.Row="1" Grid.Column="1" Style="{StaticResource TextBoxBaseStyle}" />

                        <TextBlock x:Name="ReceiptPrinterLabel" Grid.Row="2" Foreground="{StaticResource MutedTextBrush}" Margin="0,0,16,12" VerticalAlignment="Center" />
                        <TextBox x:Name="ReceiptPrinterBox" Grid.Row="2" Grid.Column="1" Style="{StaticResource TextBoxBaseStyle}" />

                        <TextBlock x:Name="CurrentLanguageLabel" Grid.Row="3" Foreground="{StaticResource MutedTextBrush}" Margin="0,0,16,12" VerticalAlignment="Center" />
                        <TextBox x:Name="CurrentLanguageBox" Grid.Row="3" Grid.Column="1" Style="{StaticResource ReadonlyTextBoxStyle}" />

                        <TextBlock x:Name="SettingsFilePathLabel" Grid.Row="4" Foreground="{StaticResource MutedTextBrush}" Margin="0,0,16,12" VerticalAlignment="Center" />
                        <TextBox x:Name="SettingsFilePathBox" Grid.Row="4" Grid.Column="1" Style="{StaticResource ReadonlyTextBoxStyle}" />

                        <TextBlock x:Name="LanguageSettingsPathLabel" Grid.Row="5" Foreground="{StaticResource MutedTextBrush}" Margin="0,0,16,12" VerticalAlignment="Center" />
                        <TextBox x:Name="LanguageSettingsPathBox" Grid.Row="5" Grid.Column="1" Style="{StaticResource ReadonlyTextBoxStyle}" />

                        <TextBlock x:Name="LogDirectoryLabel" Grid.Row="6" Foreground="{StaticResource MutedTextBrush}" Margin="0,0,16,12" VerticalAlignment="Center" />
                        <TextBox x:Name="LogDirectoryBox" Grid.Row="6" Grid.Column="1" Style="{StaticResource ReadonlyTextBoxStyle}" />

                        <TextBlock x:Name="RuntimeDirectoryLabel" Grid.Row="7" Foreground="{StaticResource MutedTextBrush}" Margin="0,0,16,0" VerticalAlignment="Center" />
                        <TextBox x:Name="RuntimeDirectoryBox" Grid.Row="7" Grid.Column="1" Style="{StaticResource ReadonlyTextBoxStyle}" Margin="0" />
                    </Grid>

                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,18,0,0">
                        <Button x:Name="ResetButton"
                                Style="{StaticResource SecondaryButtonStyle}"
                                Margin="0,0,10,0"
                                Click="ResetButton_Click" />
                        <Button x:Name="SaveButton"
                                Style="{StaticResource PrimaryButtonStyle}"
                                Click="SaveButton_Click" />
                    </StackPanel>
                </StackPanel>
            </ScrollViewer>
        </Border>
    </Grid>
</UserControl>
