<UserControl x:Class="POS_system_cs.UI.Wpf.Controls.CategoryManagementPage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Grid Margin="22">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <StackPanel Margin="0,0,0,14">
            <TextBlock x:Name="TitleText" Style="{StaticResource PageTitleTextStyle}" />
            <TextBlock x:Name="DescriptionText" Style="{StaticResource DescriptionTextStyle}" />
        </StackPanel>

        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="320" />
            </Grid.ColumnDefinitions>

            <Border Margin="0,0,16,0" Style="{StaticResource CardBorderStyle}">
                <DataGrid x:Name="CategoryGrid"
                          AutoGenerateColumns="False"
                          CanUserAddRows="False"
                          CanUserDeleteRows="False"
                          IsReadOnly="True"
                          SelectionMode="Single"
                          SelectionUnit="FullRow"
                          RowHeaderWidth="0"
                          RowHeight="40"
                          ColumnHeaderHeight="40"
                          GridLinesVisibility="Horizontal"
                          Background="{StaticResource CardBackgroundBrush}"
                          BorderThickness="0"
                          FontSize="13.5"
                          SelectionChanged="CategoryGrid_SelectionChanged" />
            </Border>

            <Border Grid.Column="1" Style="{StaticResource CardBorderStyle}">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <StackPanel>
                        <TextBlock x:Name="FormTitleText" Style="{StaticResource FormTitleTextStyle}" />
                        <TextBlock x:Name="NameLabel" Style="{StaticResource FieldLabelTextStyle}" />
                        <TextBox x:Name="NameBox" Style="{StaticResource ReadonlyTextBoxStyle}" />
                        <TextBlock x:Name="DescriptionLabel" Style="{StaticResource FieldLabelTextStyle}" />
                        <TextBox x:Name="DescriptionBox" Style="{StaticResource MultilineTextBoxStyle}" IsReadOnly="True" Background="{StaticResource SubtleBackgroundBrush}" />
                        <CheckBox x:Name="ActiveCheckBox" IsEnabled="False" Margin="0,0,0,8" />
                        <Button x:Name="EditButton" Style="{StaticResource PrimaryButtonStyle}" Click="EditButton_Click" />
                        <Button x:Name="NewButton" Style="{StaticResource SecondaryButtonStyle}" Click="NewButton_Click" />
                        <Button x:Name="DeleteButton" Style="{StaticResource DangerButtonStyle}" Click="DeleteButton_Click" />
                        <Button x:Name="RefreshButton" Style="{StaticResource SecondaryButtonStyle}" Click="RefreshButton_Click" />
                    </StackPanel>
                </ScrollViewer>
            </Border>
        </Grid>
    </Grid>
</UserControl>


