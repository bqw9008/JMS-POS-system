<Window x:Class="POS_system_cs.UI.Wpf.Controls.CategoryEditorWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Width="420"
        Height="340"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        Background="{StaticResource ShellBackgroundBrush}"
        FontFamily="Microsoft YaHei UI">
    <Grid Margin="18">
        <Grid.RowDefinitions>
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <Border Style="{StaticResource CardBorderStyle}">
            <StackPanel>
                <TextBlock x:Name="NameLabel" Style="{StaticResource FieldLabelTextStyle}" />
                <TextBox x:Name="NameBox" Style="{StaticResource TextBoxBaseStyle}" />
                <TextBlock x:Name="DescriptionLabel" Style="{StaticResource FieldLabelTextStyle}" />
                <TextBox x:Name="DescriptionBox" Style="{StaticResource MultilineTextBoxStyle}" />
                <CheckBox x:Name="ActiveCheckBox" IsChecked="True" Margin="0,0,0,8" />
            </StackPanel>
        </Border>

        <StackPanel Grid.Row="1" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,14,0,0">
            <Button x:Name="SaveButton"
                    Style="{StaticResource DialogPrimaryButtonStyle}"
                    IsDefault="True"
                    Click="SaveButton_Click" />
            <Button x:Name="CancelButton"
                    Style="{StaticResource DialogSecondaryButtonStyle}"
                    IsCancel="True" />
        </StackPanel>
    </Grid>
</Window>
