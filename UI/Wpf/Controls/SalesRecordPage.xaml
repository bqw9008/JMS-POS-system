<UserControl x:Class="POS_system_cs.UI.Wpf.Controls.SalesRecordPage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Grid Margin="22">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <WrapPanel Margin="0,0,0,14" VerticalAlignment="Center">
            <StackPanel MinWidth="260" Margin="0,0,18,0">
                <TextBlock x:Name="TitleText" FontSize="24" FontWeight="Bold" Foreground="#1F2A2E" />
                <TextBlock x:Name="DescriptionText" Foreground="#5B6969" TextWrapping="Wrap" Margin="0,4,0,0" />
            </StackPanel>
            <CheckBox x:Name="UseFromCheckBox" IsChecked="True" VerticalAlignment="Center" />
            <DatePicker x:Name="FromDatePicker" Width="140" />
            <CheckBox x:Name="UseToCheckBox" IsChecked="True" VerticalAlignment="Center" />
            <DatePicker x:Name="ToDatePicker" Width="140" />
            <Button x:Name="SearchButton" Height="34" MinWidth="76" Margin="8,0,0,0" Padding="14,0" BorderThickness="0" Background="#52796F" Foreground="#FCFAF4" Click="SearchButton_Click" />
            <Button x:Name="TodayButton" Height="34" MinWidth="76" Margin="8,0,0,0" Padding="14,0" Background="#ECF1E8" Foreground="#1F2A2E" Click="TodayButton_Click" />
            <Button x:Name="AllButton" Height="34" MinWidth="76" Margin="8,0,0,0" Padding="14,0" Background="#ECF1E8" Foreground="#1F2A2E" Click="AllButton_Click" />
        </WrapPanel>

        <Grid Grid.Row="1">
            <Grid.RowDefinitions>
                <RowDefinition Height="58*" />
                <RowDefinition Height="42*" />
            </Grid.RowDefinitions>

            <Border Margin="0,0,0,14" Padding="16" Background="#FCFAF4" BorderBrush="#DAE0D7" BorderThickness="1" CornerRadius="18">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>
                    <TextBlock x:Name="OrdersSectionTitle" FontSize="15" FontWeight="Bold" Foreground="#1F2A2E" Margin="0,0,0,10" />
                    <DataGrid x:Name="OrderGrid" Grid.Row="1" AutoGenerateColumns="False" CanUserAddRows="False" CanUserDeleteRows="False" IsReadOnly="True" SelectionMode="Single" SelectionUnit="FullRow" RowHeaderWidth="0" RowHeight="40" ColumnHeaderHeight="40" GridLinesVisibility="Horizontal" Background="#FCFAF4" BorderThickness="0" FontSize="13.5" SelectionChanged="OrderGrid_SelectionChanged" />
                </Grid>
            </Border>

            <Border Grid.Row="1" Padding="16" Background="#FCFAF4" BorderBrush="#DAE0D7" BorderThickness="1" CornerRadius="18">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>
                    <TextBlock x:Name="ItemsSectionTitle" FontSize="15" FontWeight="Bold" Foreground="#1F2A2E" Margin="0,0,0,10" />
                    <DataGrid x:Name="ItemGrid" Grid.Row="1" AutoGenerateColumns="False" CanUserAddRows="False" CanUserDeleteRows="False" IsReadOnly="True" SelectionMode="Single" SelectionUnit="FullRow" RowHeaderWidth="0" RowHeight="40" ColumnHeaderHeight="40" GridLinesVisibility="Horizontal" Background="#FCFAF4" BorderThickness="0" FontSize="13.5" />
                </Grid>
            </Border>
        </Grid>

        <TextBlock x:Name="SummaryText" Grid.Row="2" HorizontalAlignment="Right" FontWeight="SemiBold" Margin="0,14,0,0" />
    </Grid>
</UserControl>
