<UserControl x:Class="POS_system_cs.UI.Wpf.Controls.SalesRecordPage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Grid Margin="22">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <WrapPanel Margin="0,0,0,14" VerticalAlignment="Center">
            <StackPanel MinWidth="260" Margin="0,0,18,0">
                <TextBlock x:Name="TitleText" Style="{StaticResource PageTitleTextStyle}" />
                <TextBlock x:Name="DescriptionText" Style="{StaticResource DescriptionTextStyle}" />
            </StackPanel>
            <CheckBox x:Name="UseFromCheckBox" IsChecked="True" VerticalAlignment="Center" />
            <DatePicker x:Name="FromDatePicker" Width="140" />
            <CheckBox x:Name="UseToCheckBox" IsChecked="True" VerticalAlignment="Center" />
            <DatePicker x:Name="ToDatePicker" Width="140" />
            <Button x:Name="SearchButton" Style="{StaticResource CompactPrimaryButtonStyle}" Click="SearchButton_Click" />
            <Button x:Name="TodayButton" Style="{StaticResource CompactSecondaryButtonStyle}" Click="TodayButton_Click" />
            <Button x:Name="AllButton" Style="{StaticResource CompactSecondaryButtonStyle}" Click="AllButton_Click" />
        </WrapPanel>

        <Grid Grid.Row="1">
            <Grid.RowDefinitions>
                <RowDefinition Height="58*" />
                <RowDefinition Height="42*" />
            </Grid.RowDefinitions>

            <Border Margin="0,0,0,14" Style="{StaticResource CardBorderStyle}">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>
                    <TextBlock x:Name="OrdersSectionTitle" Style="{StaticResource SectionTitleTextStyle}" />
                    <DataGrid x:Name="OrderGrid" Grid.Row="1" AutoGenerateColumns="False" CanUserAddRows="False" CanUserDeleteRows="False" IsReadOnly="True" SelectionMode="Single" SelectionUnit="FullRow" RowHeaderWidth="0" RowHeight="40" ColumnHeaderHeight="40" GridLinesVisibility="Horizontal" Background="{StaticResource CardBackgroundBrush}" BorderThickness="0" FontSize="13.5" SelectionChanged="OrderGrid_SelectionChanged" />
                </Grid>
            </Border>

            <Border Grid.Row="1" Style="{StaticResource CardBorderStyle}">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>
                    <TextBlock x:Name="ItemsSectionTitle" Style="{StaticResource SectionTitleTextStyle}" />
                    <DataGrid x:Name="ItemGrid" Grid.Row="1" AutoGenerateColumns="False" CanUserAddRows="False" CanUserDeleteRows="False" IsReadOnly="True" SelectionMode="Single" SelectionUnit="FullRow" RowHeaderWidth="0" RowHeight="40" ColumnHeaderHeight="40" GridLinesVisibility="Horizontal" Background="{StaticResource CardBackgroundBrush}" BorderThickness="0" FontSize="13.5" />
                </Grid>
            </Border>
        </Grid>

        <TextBlock x:Name="SummaryText" Grid.Row="2" HorizontalAlignment="Right" FontWeight="SemiBold" Margin="0,14,0,0" />
    </Grid>
</UserControl>


