<Window x:Class="POS_system_cs.UI.Wpf.Controls.PaymentDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Width="480"
        Height="340"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        Background="{StaticResource ShellBackgroundBrush}"
        FontFamily="Microsoft YaHei UI"
        KeyDown="Window_KeyDown">
    <Grid Margin="20">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="82" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <TextBlock x:Name="PayableLabel" VerticalAlignment="Center" Foreground="{StaticResource MutedTextBrush}" Margin="0,0,12,10" />
        <TextBox x:Name="PayableBox" Grid.Column="1" Height="38" FontSize="15" TextAlignment="Right" VerticalContentAlignment="Center" IsReadOnly="True" Background="{StaticResource SubtleBackgroundBrush}" BorderBrush="{StaticResource BorderSoftBrush}" Margin="0,0,0,10" />
        <TextBlock x:Name="DiscountLabel" Grid.Row="1" VerticalAlignment="Center" Foreground="{StaticResource MutedTextBrush}" Margin="0,0,12,10" />
        <TextBox x:Name="DiscountBox" Grid.Row="1" Grid.Column="1" Height="38" FontSize="15" TextAlignment="Right" VerticalContentAlignment="Center" IsReadOnly="True" Background="{StaticResource SubtleBackgroundBrush}" BorderBrush="{StaticResource BorderSoftBrush}" Margin="0,0,0,10" />
        <TextBlock x:Name="ReceivedLabel" Grid.Row="2" VerticalAlignment="Center" Foreground="{StaticResource MutedTextBrush}" Margin="0,0,12,10" />
        <TextBox x:Name="ReceivedBox" Grid.Row="2" Grid.Column="1" Height="38" FontSize="15" TextAlignment="Right" VerticalContentAlignment="Center" Margin="0,0,0,10" TextChanged="ReceivedBox_TextChanged" />
        <TextBlock x:Name="ChangeLabel" Grid.Row="3" VerticalAlignment="Center" Foreground="{StaticResource MutedTextBrush}" Margin="0,0,12,10" />
        <TextBox x:Name="ChangeBox" Grid.Row="3" Grid.Column="1" Height="38" FontSize="15" TextAlignment="Right" VerticalContentAlignment="Center" IsReadOnly="True" Background="{StaticResource SubtleBackgroundBrush}" BorderBrush="{StaticResource BorderSoftBrush}" Margin="0,0,0,10" />
        <TextBlock x:Name="StatusText" Grid.Row="4" Grid.Column="1" Foreground="{StaticResource TextBrush}" Margin="0,8,0,0" />
        <TextBlock x:Name="HintText" Grid.Row="5" Grid.Column="1" Foreground="{StaticResource MutedTextBrush}" FontSize="12" TextWrapping="Wrap" Margin="0,10,0,14" />
        <StackPanel Grid.Row="6" Grid.Column="1" Orientation="Horizontal" HorizontalAlignment="Right">
            <Button x:Name="CompleteButton" Style="{StaticResource DialogPrimaryButtonStyle}" IsDefault="True" Click="CompleteButton_Click" />
            <Button x:Name="OnlineButton" Style="{StaticResource DialogSecondaryButtonStyle}" Click="OnlineButton_Click" />
            <Button x:Name="CashButton" Style="{StaticResource DialogSecondaryButtonStyle}" Click="CashButton_Click" />
            <Button x:Name="CancelButton" Style="{StaticResource DialogSecondaryButtonStyle}" IsCancel="True" />
        </StackPanel>
    </Grid>
</Window>


