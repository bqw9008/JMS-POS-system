<UserControl x:Class="POS_system_cs.UI.Wpf.Controls.CashierPage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Focusable="True"
             Background="{StaticResource ShellBackgroundBrush}">
    <Grid Margin="22">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <Border Margin="0,0,0,16" Style="{StaticResource CardBorderStyle}" Padding="18">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <StackPanel Margin="0,0,18,0">
                    <TextBlock x:Name="TitleText" Style="{StaticResource PageTitleTextStyle}" />
                    <TextBlock x:Name="DescriptionText" Foreground="{StaticResource MutedTextBrush}" Margin="0,4,0,0" />
                </StackPanel>

                <TextBox x:Name="ProductInputTextBox"
                         Grid.Column="1"
                         MinWidth="300"
                         Height="46"
                         VerticalContentAlignment="Center"
                         FontSize="16"
                         Padding="14,0" />
                <Button x:Name="AddButton"
                        Grid.Column="2"
                        Height="42"
                        MinWidth="104"
                        Margin="10,0,0,0"
                        Padding="18,0"
                        BorderThickness="0"
                        Background="{StaticResource PrimaryBrush}"
                        Foreground="{StaticResource PrimaryForegroundBrush}"
                        FontWeight="SemiBold"
                        Click="AddButton_Click" />
                <Button x:Name="ClearButton"
                        Grid.Column="3"
                        Height="42"
                        MinWidth="104"
                        Margin="10,0,0,0"
                        Padding="18,0"
                        BorderBrush="{StaticResource BorderSoftBrush}"
                        BorderThickness="1"
                        Background="{StaticResource SecondaryButtonBrush}"
                        Foreground="{StaticResource TextBrush}"
                        Click="ClearButton_Click" />
            </Grid>
        </Border>

        <Border Grid.Row="1" Margin="0,0,0,16" Style="{StaticResource CardBorderStyle}" Padding="18">
            <DataGrid x:Name="CartGrid"
                      AutoGenerateColumns="False"
                      CanUserAddRows="False"
                      CanUserDeleteRows="False"
                      IsReadOnly="True"
                      SelectionMode="Single"
                      SelectionUnit="FullRow"
                      RowHeaderWidth="0"
                      GridLinesVisibility="Horizontal"
                      HeadersVisibility="Column"
                      Background="{StaticResource CardBackgroundBrush}"
                      BorderThickness="0"
                      FontSize="14"
                      RowHeight="42"
                      ColumnHeaderHeight="40" />
        </Border>

        <Border Grid.Row="2" Style="{StaticResource CardBorderStyle}" Padding="18">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="140" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <TextBlock x:Name="DiscountLabel" VerticalAlignment="Center" Foreground="{StaticResource MutedTextBrush}" Margin="0,0,10,0" />
                <TextBox x:Name="DiscountTextBox"
                         Grid.Column="1"
                         Height="40"
                         VerticalContentAlignment="Center"
                         TextAlignment="Right"
                         Text="0.00"
                         Padding="10,0" />
                <StackPanel Grid.Column="2" Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center" Margin="20,0,20,0">
                    <StackPanel Margin="20,0,0,0" VerticalAlignment="Center">
                        <TextBlock x:Name="TotalLabel" Foreground="{StaticResource MutedTextBrush}" HorizontalAlignment="Right" />
                        <TextBlock x:Name="TotalAmountText" Text="0.00" Style="{StaticResource PageTitleTextStyle}" HorizontalAlignment="Right" />
                    </StackPanel>
                    <StackPanel Margin="20,0,0,0" VerticalAlignment="Center">
                        <TextBlock x:Name="PayableLabel" Foreground="{StaticResource MutedTextBrush}" HorizontalAlignment="Right" />
                        <TextBlock x:Name="PayableAmountText" Text="0.00" Style="{StaticResource PageTitleTextStyle}" HorizontalAlignment="Right" />
                    </StackPanel>
                </StackPanel>
                <Button x:Name="CheckoutButton"
                        Grid.Column="3"
                        Height="46"
                        MinWidth="132"
                        Margin="10,0,0,0"
                        Padding="18,0"
                        BorderThickness="0"
                        Background="{StaticResource PrimaryBrush}"
                        Foreground="{StaticResource PrimaryForegroundBrush}"
                        FontWeight="SemiBold"
                        Click="CheckoutButton_Click" />
            </Grid>
        </Border>

        <TextBlock x:Name="ShortcutHintText"
                   Grid.Row="3"
                   Foreground="{StaticResource MutedTextBrush}"
                   FontSize="12"
                   Margin="2,14,2,0"
                   TextWrapping="Wrap" />
    </Grid>
</UserControl>


