<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Color x:Key="AppBackgroundColor">#EDF1EB</Color>
    <Color x:Key="ShellBackgroundColor">#FAF8F1</Color>
    <Color x:Key="CardBackgroundColor">#FCFAF4</Color>
    <Color x:Key="SubtleBackgroundColor">#F4F6EF</Color>
    <Color x:Key="BorderSoftColor">#DAE0D7</Color>
    <Color x:Key="TextColor">#1F2A2E</Color>
    <Color x:Key="MutedTextColor">#5B6969</Color>
    <Color x:Key="PrimaryColor">#52796F</Color>
    <Color x:Key="SecondaryButtonColor">#ECF1E8</Color>
    <Color x:Key="DangerBackgroundColor">#FCEFEB</Color>
    <Color x:Key="DangerTextColor">#9D3E30</Color>
    <Color x:Key="NavStartColor">#E0EAE0</Color>
    <Color x:Key="NavEndColor">#CDDDD5</Color>
    <Color x:Key="NavButtonBackgroundColor">#EFF4EC</Color>

    <SolidColorBrush x:Key="AppBackgroundBrush" Color="{StaticResource AppBackgroundColor}" />
    <SolidColorBrush x:Key="ShellBackgroundBrush" Color="{StaticResource ShellBackgroundColor}" />
    <SolidColorBrush x:Key="CardBackgroundBrush" Color="{StaticResource CardBackgroundColor}" />
    <SolidColorBrush x:Key="SubtleBackgroundBrush" Color="{StaticResource SubtleBackgroundColor}" />
    <SolidColorBrush x:Key="BorderSoftBrush" Color="{StaticResource BorderSoftColor}" />
    <SolidColorBrush x:Key="TextBrush" Color="{StaticResource TextColor}" />
    <SolidColorBrush x:Key="MutedTextBrush" Color="{StaticResource MutedTextColor}" />
    <SolidColorBrush x:Key="PrimaryBrush" Color="{StaticResource PrimaryColor}" />
    <SolidColorBrush x:Key="PrimaryForegroundBrush" Color="{StaticResource CardBackgroundColor}" />
    <SolidColorBrush x:Key="SecondaryButtonBrush" Color="{StaticResource SecondaryButtonColor}" />
    <SolidColorBrush x:Key="DangerBackgroundBrush" Color="{StaticResource DangerBackgroundColor}" />
    <SolidColorBrush x:Key="DangerTextBrush" Color="{StaticResource DangerTextColor}" />
    <SolidColorBrush x:Key="NavButtonBackgroundBrush" Color="{StaticResource NavButtonBackgroundColor}" />

    <LinearGradientBrush x:Key="NavigationBackgroundBrush" StartPoint="0,0" EndPoint="0,1">
        <GradientStop Color="{StaticResource NavStartColor}" Offset="0" />
        <GradientStop Color="{StaticResource NavEndColor}" Offset="1" />
    </LinearGradientBrush>

    <Style x:Key="PageRootStyle" TargetType="UserControl">
        <Setter Property="Background" Value="{StaticResource ShellBackgroundBrush}" />
    </Style>

    <Style x:Key="DialogWindowStyle" TargetType="Window">
        <Setter Property="Background" Value="{StaticResource ShellBackgroundBrush}" />
        <Setter Property="FontFamily" Value="Microsoft YaHei UI" />
    </Style>

    <Style x:Key="PageTitleTextStyle" TargetType="TextBlock">
        <Setter Property="FontSize" Value="24" />
        <Setter Property="FontWeight" Value="Bold" />
        <Setter Property="Foreground" Value="{StaticResource TextBrush}" />
    </Style>

    <Style x:Key="DescriptionTextStyle" TargetType="TextBlock">
        <Setter Property="Foreground" Value="{StaticResource MutedTextBrush}" />
        <Setter Property="TextWrapping" Value="Wrap" />
        <Setter Property="Margin" Value="0,4,0,0" />
    </Style>

    <Style x:Key="FormTitleTextStyle" TargetType="TextBlock">
        <Setter Property="FontSize" Value="18" />
        <Setter Property="FontWeight" Value="Bold" />
        <Setter Property="Foreground" Value="{StaticResource TextBrush}" />
        <Setter Property="Margin" Value="0,0,0,12" />
    </Style>

    <Style x:Key="SectionTitleTextStyle" TargetType="TextBlock">
        <Setter Property="FontSize" Value="15" />
        <Setter Property="FontWeight" Value="Bold" />
        <Setter Property="Foreground" Value="{StaticResource TextBrush}" />
        <Setter Property="Margin" Value="0,0,0,10" />
    </Style>

    <Style x:Key="FieldLabelTextStyle" TargetType="TextBlock">
        <Setter Property="Foreground" Value="{StaticResource MutedTextBrush}" />
        <Setter Property="Margin" Value="0,0,0,5" />
    </Style>

    <Style x:Key="InlineLabelTextStyle" TargetType="TextBlock">
        <Setter Property="Foreground" Value="{StaticResource MutedTextBrush}" />
        <Setter Property="VerticalAlignment" Value="Center" />
    </Style>

    <Style x:Key="MetricValueTextStyle" TargetType="TextBlock">
        <Setter Property="FontSize" Value="24" />
        <Setter Property="FontWeight" Value="Bold" />
        <Setter Property="Foreground" Value="{StaticResource TextBrush}" />
        <Setter Property="Margin" Value="0,10,0,0" />
    </Style>

    <Style x:Key="CardBorderStyle" TargetType="Border">
        <Setter Property="Padding" Value="16" />
        <Setter Property="Background" Value="{StaticResource CardBackgroundBrush}" />
        <Setter Property="BorderBrush" Value="{StaticResource BorderSoftBrush}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="CornerRadius" Value="18" />
    </Style>

    <Style x:Key="TextBoxBaseStyle" TargetType="TextBox">
        <Setter Property="Height" Value="38" />
        <Setter Property="Padding" Value="10,0" />
        <Setter Property="VerticalContentAlignment" Value="Center" />
        <Setter Property="Margin" Value="0,0,0,10" />
    </Style>

    <Style x:Key="ReadonlyTextBoxStyle" TargetType="TextBox" BasedOn="{StaticResource TextBoxBaseStyle}">
        <Setter Property="IsReadOnly" Value="True" />
        <Setter Property="Background" Value="{StaticResource SubtleBackgroundBrush}" />
        <Setter Property="BorderBrush" Value="{StaticResource BorderSoftBrush}" />
    </Style>

    <Style x:Key="MultilineTextBoxStyle" TargetType="TextBox" BasedOn="{StaticResource TextBoxBaseStyle}">
        <Setter Property="Height" Value="88" />
        <Setter Property="Padding" Value="10" />
        <Setter Property="VerticalContentAlignment" Value="Top" />
        <Setter Property="TextWrapping" Value="Wrap" />
        <Setter Property="AcceptsReturn" Value="True" />
    </Style>

    <Style x:Key="ComboBoxBaseStyle" TargetType="ComboBox">
        <Setter Property="Height" Value="38" />
        <Setter Property="Padding" Value="8,0" />
        <Setter Property="VerticalContentAlignment" Value="Center" />
        <Setter Property="Margin" Value="0,0,0,10" />
    </Style>

    <Style x:Key="DataGridBaseStyle" TargetType="DataGrid">
        <Setter Property="AutoGenerateColumns" Value="False" />
        <Setter Property="CanUserAddRows" Value="False" />
        <Setter Property="CanUserDeleteRows" Value="False" />
        <Setter Property="IsReadOnly" Value="True" />
        <Setter Property="SelectionMode" Value="Single" />
        <Setter Property="SelectionUnit" Value="FullRow" />
        <Setter Property="RowHeaderWidth" Value="0" />
        <Setter Property="RowHeight" Value="40" />
        <Setter Property="ColumnHeaderHeight" Value="40" />
        <Setter Property="GridLinesVisibility" Value="Horizontal" />
        <Setter Property="Background" Value="{StaticResource CardBackgroundBrush}" />
        <Setter Property="BorderThickness" Value="0" />
        <Setter Property="FontSize" Value="13.5" />
    </Style>

    <Style x:Key="PrimaryButtonStyle" TargetType="Button">
        <Setter Property="Height" Value="40" />
        <Setter Property="MinWidth" Value="110" />
        <Setter Property="Margin" Value="0,8,0,0" />
        <Setter Property="Padding" Value="14,0" />
        <Setter Property="BorderThickness" Value="0" />
        <Setter Property="Background" Value="{StaticResource PrimaryBrush}" />
        <Setter Property="Foreground" Value="{StaticResource PrimaryForegroundBrush}" />
        <Setter Property="Cursor" Value="Hand" />
    </Style>

    <Style x:Key="SecondaryButtonStyle" TargetType="Button" BasedOn="{StaticResource PrimaryButtonStyle}">
        <Setter Property="BorderBrush" Value="{StaticResource BorderSoftBrush}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="Background" Value="{StaticResource SecondaryButtonBrush}" />
        <Setter Property="Foreground" Value="{StaticResource TextBrush}" />
    </Style>

    <Style x:Key="DangerButtonStyle" TargetType="Button" BasedOn="{StaticResource PrimaryButtonStyle}">
        <Setter Property="Background" Value="{StaticResource DangerBackgroundBrush}" />
        <Setter Property="Foreground" Value="{StaticResource DangerTextBrush}" />
    </Style>

    <Style x:Key="CompactPrimaryButtonStyle" TargetType="Button" BasedOn="{StaticResource PrimaryButtonStyle}">
        <Setter Property="Height" Value="34" />
        <Setter Property="MinWidth" Value="76" />
        <Setter Property="Margin" Value="8,0,0,0" />
    </Style>

    <Style x:Key="CompactSecondaryButtonStyle" TargetType="Button" BasedOn="{StaticResource SecondaryButtonStyle}">
        <Setter Property="Height" Value="34" />
        <Setter Property="MinWidth" Value="76" />
        <Setter Property="Margin" Value="8,0,0,0" />
    </Style>

    <Style x:Key="DialogPrimaryButtonStyle" TargetType="Button" BasedOn="{StaticResource CompactPrimaryButtonStyle}">
        <Setter Property="MinWidth" Value="90" />
        <Setter Property="Padding" Value="12,0" />
    </Style>

    <Style x:Key="DialogSecondaryButtonStyle" TargetType="Button" BasedOn="{StaticResource CompactSecondaryButtonStyle}">
        <Setter Property="MinWidth" Value="82" />
        <Setter Property="Padding" Value="12,0" />
    </Style>

    <Style x:Key="NavigationButtonStyle" TargetType="Button">
        <Setter Property="Height" Value="44" />
        <Setter Property="HorizontalContentAlignment" Value="Left" />
        <Setter Property="Margin" Value="0,0,0,8" />
        <Setter Property="Padding" Value="16,0,12,0" />
        <Setter Property="FontSize" Value="14" />
        <Setter Property="Foreground" Value="{StaticResource TextBrush}" />
        <Setter Property="Background" Value="{StaticResource NavButtonBackgroundBrush}" />
        <Setter Property="BorderThickness" Value="0" />
        <Setter Property="Cursor" Value="Hand" />
    </Style>

    <Style x:Key="ActiveNavigationButtonStyle" TargetType="Button" BasedOn="{StaticResource NavigationButtonStyle}">
        <Setter Property="Background" Value="{StaticResource PrimaryBrush}" />
        <Setter Property="Foreground" Value="{StaticResource PrimaryForegroundBrush}" />
    </Style>
</ResourceDictionary>

