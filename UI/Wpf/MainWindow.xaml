<Window x:Class="POS_system_cs.UI.Wpf.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Width="1320"
        Height="840"
        MinWidth="1180"
        MinHeight="760"
        WindowStartupLocation="CenterScreen"
        Background="#EDF1EB"
        FontFamily="Microsoft YaHei UI">
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="236" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>

        <Border Grid.Column="0">
            <Border.Background>
                <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                    <GradientStop Color="#E0EAE0" Offset="0" />
                    <GradientStop Color="#CDDDD5" Offset="1" />
                </LinearGradientBrush>
            </Border.Background>
            <ScrollViewer VerticalScrollBarVisibility="Auto">
                <StackPanel Margin="16,20,16,20">
                    <TextBlock Text="POS System"
                               FontSize="24"
                               FontWeight="Bold"
                               Foreground="#1F2A2E"
                               Margin="6,0,6,4" />
                    <TextBlock x:Name="SubtitleText"
                               FontSize="12"
                               Foreground="#5B6969"
                               Margin="6,0,6,24" />
                    <ComboBox x:Name="LanguageSelector"
                              Margin="0,0,0,18"
                              Height="34"
                              SelectedValuePath="Tag"
                              DisplayMemberPath="Content"
                              SelectionChanged="LanguageSelector_SelectionChanged" />
                    <StackPanel x:Name="NavigationItemsPanel" />
                </StackPanel>
            </ScrollViewer>
        </Border>

        <Border Grid.Column="1"
                Margin="18"
                Background="#FAF8F1"
                CornerRadius="18"
                BorderBrush="#DAE0D7"
                BorderThickness="1">
            <ContentControl x:Name="ContentHost" />
        </Border>
    </Grid>
</Window>
